# ============================================
# CoRide Django Backend - Environment Variables Template
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit the .env file to git

# ============================================
# SECTION 1 - Django Core Settings
# ============================================
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_django_secret_key_here_50_characters_minimum
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=coride.settings
TIME_ZONE=Asia/Kolkata
LANGUAGE_CODE=en-us

# ============================================
# SECTION 2 - PostgreSQL Database
# ============================================
# Install PostgreSQL: https://www.postgresql.org/download/
# Create database: CREATE DATABASE coride_db;
DATABASE_NAME=coride_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_postgresql_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ============================================
# SECTION 3 - JWT Authentication
# ============================================
# Access token expires in minutes, refresh token in days
JWT_ACCESS_TOKEN_EXPIRY=60
JWT_REFRESH_TOKEN_EXPIRY=7
JWT_SIGNING_KEY=your_jwt_signing_key_here_use_strong_random_string

# ============================================
# SECTION 4 - Razorpay Payment Gateway (India)
# ============================================
# Sign up: https://razorpay.com/
# Get credentials: https://dashboard.razorpay.com/app/keys
# Test mode keys start with: rzp_test_
# Live mode keys start with: rzp_live_
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ============================================
# SECTION 5 - Google Maps API
# ============================================
# Create project: https://console.cloud.google.com/
# Enable APIs: Maps JavaScript API, Geocoding API, Distance Matrix API, Directions API
# Create credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# SECTION 6 - Cloudinary File Storage
# ============================================
# Sign up: https://cloudinary.com/users/register/free
# Get credentials: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# SECTION 7 - Firebase Push Notifications
# ============================================
# Create project: https://console.firebase.google.com/
# Generate service account: Project Settings > Service Accounts > Generate New Private Key
# Save JSON file as firebase-credentials.json in project root
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ============================================
# SECTION 8 - Twilio SMS/OTP Service
# ============================================
# Sign up: https://www.twilio.com/try-twilio
# Get credentials: https://console.twilio.com/
# Buy phone number: https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# SECTION 9 - Redis Cache & Sessions
# ============================================
# Install Redis: https://redis.io/download
# Windows: https://github.com/microsoftarchive/redis/releases
# Start Redis: redis-server
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# ============================================
# SECTION 10 - Celery Background Tasks
# ============================================
# Uses Redis as message broker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# SECTION 11 - Email SMTP Configuration
# ============================================
# Gmail: Enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
# SendGrid: https://sendgrid.com/ (alternative)
# Mailgun: https://www.mailgun.com/ (alternative)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here
DEFAULT_FROM_EMAIL=CoRide <noreply@coride.in>

# ============================================
# SECTION 12 - Platform Business Settings
# ============================================
# Commission and pricing rules for CoRide platform
PLATFORM_COMMISSION_PERCENT=15
OTP_EXPIRY_MINUTES=10
MAX_SEATS_PER_BOOKING=6
RIDE_SEARCH_RADIUS_KM=50
MIN_RIDE_PRICE=10
MAX_RIDE_PRICE=10000
CANCELLATION_CHARGE_PERCENT=10
FREE_CANCELLATION_MINUTES=30

# ============================================
# SECTION 13 - Frontend & App URLs
# ============================================
# Update these for production deployment
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3000/admin
APP_DEEP_LINK=coride://

# ============================================
# SECTION 14 - Security & CORS
# ============================================
# Add production domains when deploying
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000
