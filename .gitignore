# ============================================
# CoRide Django Backend - .gitignore
# ============================================
# Protects secrets, credentials, and keeps repository clean
# Never commit sensitive data or generated files

# ============================================
# CRITICAL: Environment Variables & Secrets
# ============================================
# Contains API keys, database passwords, JWT secrets
.env
.env.*
!.env.example
*.env

# ============================================
# Firebase Credentials
# ============================================
# Firebase Admin SDK service account JSON - NEVER COMMIT
*firebase*.json
serviceAccountKey.json
firebase-adminsdk*.json

# ============================================
# SSL Certificates & Keys
# ============================================
# Security certificates and private keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# ============================================
# Python Cache & Compiled Files
# ============================================
# Bytecode and cache files generated by Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python

# ============================================
# Virtual Environments
# ============================================
# Python virtual environment directories
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
virtualenv/

# ============================================
# Poetry Package Manager
# ============================================
# Poetry lock file can be committed, but local config should not
poetry.lock
.poetry/

# ============================================
# Django Generated Files
# ============================================
# SQLite database (use PostgreSQL in production)
*.sqlite3
*.sqlite3-journal
db.sqlite3

# Static files collected by collectstatic
staticfiles/
static_root/
static_cdn/

# User uploaded media files (use Cloudinary in production)
media/
media_root/
media_cdn/

# Django migrations - KEEP these in git, but ignore if auto-generated
# migrations/

# ============================================
# Log Files
# ============================================
# Application logs - never commit logs with user data
logs/*.log
*.log
log/
*.log.*

# ============================================
# Celery Task Queue
# ============================================
# Celery beat schedule and process files
celerybeat-schedule
celerybeat.pid
celerybeat-schedule.db

# ============================================
# Database Files & Dumps
# ============================================
# Database backups and dumps contain sensitive data
*.sql
*.dump
*.db
*.sqlite
*.backup
*.bak

# ============================================
# Testing & Coverage
# ============================================
# Test coverage reports and cache
.coverage
.coverage.*
htmlcov/
.tox/
.pytest_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
.cache

# ============================================
# Type Checking & Linting
# ============================================
# mypy type checker cache
.mypy_cache/
.dmypy.json
dmypy.json

# Pylint reports
pylint-report.txt

# ============================================
# Distribution & Packaging
# ============================================
# Build artifacts and distribution files
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# IDE & Editor Settings
# ============================================
# VS Code workspace settings
.vscode/
.vscode/*
!.vscode/extensions.json

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# Jupyter Notebooks
# ============================================
# Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================
# Windows System Files
# ============================================
# Windows generated files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
desktop.ini
*.lnk
$RECYCLE.BIN/

# ============================================
# macOS System Files
# ============================================
# macOS generated files (for cross-platform teams)
.DS_Store
.AppleDouble
.LSOverride
._*

# ============================================
# Backup Files
# ============================================
# Editor and system backup files
*.bak
*.backup
*.tmp
*.temp
*~

# ============================================
# Test Fixtures with Real Data
# ============================================
# Test data that might contain PII or sensitive info
fixtures/real_data/
test_data/real/
*_real_data.json

# ============================================
# Redis Dump Files
# ============================================
# Redis database dumps
dump.rdb
*.rdb

# ============================================
# Documentation Build
# ============================================
# Sphinx documentation builds
docs/_build/
docs/_static/
docs/_templates/

# ============================================
# Temporary Files
# ============================================
# Various temporary files
*.tmp
*.temp
tmp/
temp/
